# ============================================================
# Distributed Job Scheduler Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- Application ----
NODE_ENV=development

# ---- PostgreSQL ----
POSTGRES_DB=jobscheduler
POSTGRES_USER=jobscheduler
POSTGRES_PASSWORD=change_me_in_production

# ---- Redis ----
REDIS_PASSWORD=change_me_in_production

# ---- JWT Secrets (MUST be random 32+ character strings) ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change_me_to_random_32_char_string_access
JWT_REFRESH_SECRET=change_me_to_random_32_char_string_refresh

# ---- Backend ----
DATABASE_URL=postgresql://jobscheduler:change_me_in_production@localhost:5432/jobscheduler?schema=public
REDIS_URL=redis://:change_me_in_production@localhost:6379
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:5173,http://localhost:80
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
PORT=3000

# ---- Worker ----
WORKER_CONCURRENCY=5
WORKER_QUEUES=default,email,payment,reports
HEARTBEAT_INTERVAL_MS=10000
LEASE_CHECK_INTERVAL_MS=15000
WORKER_STALE_THRESHOLD_MS=30000
ENABLE_LEASE_MANAGER=true
ENABLE_SCHEDULER=true

# ---- Frontend (Vite) ----
VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=http://localhost:3000
